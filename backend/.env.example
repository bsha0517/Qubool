# Database
DATABASE_URL="postgresql://user:password@localhost:5432/qubool?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# SMS OTP (Twilio, or swap for a local Pakistani SMS gateway e.g. Telesign/Zong/Jazz APIs)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# File storage (photos, CNIC images, selfies)
AWS_REGION="me-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="qubool-uploads"
MAX_UPLOAD_MB=8
# Used only by the local-disk upload fallback when AWS isn't configured —
# must be reachable from wherever the client's browser runs.
SELF_BASE_URL="http://localhost:4000"

# CNIC/ID verification (KYC provider — Onfido/Persona/local vendor)
KYC_PROVIDER_BASE_URL=""
KYC_PROVIDER_API_KEY=""
# Pepper mixed into the CNIC hash before storage — keep this secret and
# rotate only with a plan to re-hash existing records.
CNIC_HASH_PEPPER="change-this-to-a-long-random-string"

# Chat content moderation (hosted classifier endpoint, e.g. an OpenAI-style
# /moderations proxy or a Perspective API wrapper)
MODERATION_API_URL=""
MODERATION_API_KEY=""

# Redis (rate limiting; also usable later for caching / Socket.io scaling)
REDIS_URL="redis://localhost:6379"
